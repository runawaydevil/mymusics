# API (Fastify) — explicit port wins over PORT_INDEX
# PORT=38471

# Slot 0..3 into predefined pools (see config/ports.ts). Same index pairs API + Vite dev by default.
# PORT_INDEX=0

# Vite dev server port — overrides paired slot when set
# VITE_DEV_PORT=38472

# Optional: different slot for Vite only (otherwise PORT_INDEX is used)
# VITE_PORT_INDEX=0

# Absolute path or path relative to cwd when starting `npm run start` / `dev:api`
# Default in code: ../../data/metadata.tsv from server dir (repo MySpace/data/metadata.tsv)
METADATA_TSV=../data/metadata.tsv

# Optional: Internet Archive item identifier (default: myspace_dragon_hoard_2010)
# IA_ITEM_ID=myspace_dragon_hoard_2010

# Serve Vite build from dist/ on the same port as the API (production / PM2).
# SERVE_STATIC=true
